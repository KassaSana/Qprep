# Supabase (create a project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Anthropic — used by the Nudge Engine and (optionally) the freeform grader.
# (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# Freeform answer grader (lib/grade-freeform.ts)
# Default: groq when GROQ_API_KEY is set, else keyword (offline).
# Override with GRADER_PROVIDER=groq|anthropic|ollama|keyword.
GRADER_PROVIDER=groq
GROQ_API_KEY=YOUR_GROQ_KEY
# Optional model override; defaults are llama-3.3-70b-versatile (groq),
# claude-haiku-4-7 (anthropic), llama3.1:8b (ollama).
# GRADER_MODEL=llama-3.3-70b-versatile
# OLLAMA_URL=http://localhost:11434

# Code runner (lib/runner.ts) — Piston-compatible
# Default: https://emkc.org/api/v2/piston (public). Self-host or swap freely.
CODE_RUNNER_URL=https://emkc.org/api/v2/piston

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth feature flag (Phase 3 item 2 — real auth via Supabase Auth)
# Default: false — every visitor stays on the anon-cookie identity (`qprep_anon`).
# Slice 1 of the rollout (lib/identity.ts + migration 0005) is wired but inert
# while this flag is anything other than the literal string "true". Flip to
# "true" only after slice 2 (sign-in UI + post-sign-in linking via
# link_anon_to_user) ships, otherwise the UI will still show anon-only.
NEXT_PUBLIC_AUTH_ENABLED=false

# Analytics provider (lib/analytics.ts)
# Default: console in dev, noop in prod. Set explicitly to override.
#   console — log every event to console.info (useful in staging / canary)
#   noop    — drop every event silently
# When picking a real provider (PostHog, Vercel Analytics, Plausible, etc.),
# add a new file under lib/ analogous to a provider implementation and extend
# getProvider() to return it. The typed event catalogue in lib/analytics.ts
# is the single source of truth for what events exist.
# NEXT_PUBLIC_ANALYTICS_PROVIDER=console
